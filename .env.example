# Copy this to .env and fill values. DO NOT commit your real .env into git.

# ===== Deployment / Docker Naming =====
APP_NAME=helpcentre
HELPCENTRE_IMAGE=your-dockerhub-user/helpcentre-api:latest
HELPCENTRE_API_HOST_PORT=8080
POSTGRES_HOST_PORT=5432

# ===== Database Configuration =====
# PostgreSQL connection string. In Docker Compose this is overridden to use
# the compose service name `helpcentre_postgres`.
POSTGRES_USER=helpcentre_user
POSTGRES_PASSWORD=helpcentre_pass
POSTGRES_DB=helpcentre_db
DATABASE_URL=postgresql://helpcentre_user:helpcentre_pass@helpcentre_postgres:5432/helpcentre_db

# ===== LLM Configuration =====
# Google Generative Language API key.
# Create one in Google AI Studio and keep the real value only in your local .env.
GEMMA_API_KEY=your_google_genai_api_key_here
GOOGLE_API_KEY=your_google_genai_api_key_here
# GEMMA_MODEL: choose one from `scripts/gemma_models_list.txt` (example: models/gemma-4-31b-it)
GEMMA_MODEL=models/gemma-4-31b-it

# ===== Embedding Model Configuration =====
# Gemini embedding model used for semantic search and pgvector indexing
EMBEDDING_PROVIDER=gemini
EMBEDDING_MODEL=models/gemini-embedding-2
EMBEDDING_DIM=1536
VECTOR_BACKEND=postgres

# ===== CORS Configuration =====
# Comma-separated list of allowed origins, or * for all
CORS_ALLOW_ORIGINS=*

# ===== Reranker Configuration =====
# Enabled by default. If the model cannot be loaded, the API continues without reranking.
RERANKER_ENABLED=true
RERANKER_MODEL=cross-encoder/ms-marco-MiniLM-L-6-v2
RERETRIEVAL_K=20

# ===== Optional Runtime Configuration =====
# Batch size for embedding indexing
BATCH_SIZE=64
INDEX_PROJECTS=tb,cervical_cancer
CHUNKING_STRATEGY=semantic
BOOTSTRAP_INDEX_ON_START=0
WAIT_FOR_DB=1
DB_WAIT_TIMEOUT_SECONDS=90

# LOG_LEVEL=info
